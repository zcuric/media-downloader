# Copy this file to .env for local release builds.
# Never commit .env or Apple key/certificate files.

# Developer ID Application signing identity from:
# security find-identity -v -p codesigning
MEDIA_DOWNLOADER_DEVELOPER_ID="Developer ID Application: Your Name (TEAMID)"

# App bundle metadata.
BUNDLE_ID="com.pixelpoint.MediaDownloader"
APP_VERSION="0.1.0"
APP_BUILD="1"

# Preferred notarization auth: App Store Connect API key.
APPLE_API_KEY_ID="ABC123DEFG"
APPLE_API_ISSUER_ID="00000000-0000-0000-0000-000000000000"
APPLE_API_KEY_PATH="/absolute/path/to/AuthKey_ABC123DEFG.p8"

# Alternative notarization auth. Leave unset when using API key auth.
# APPLE_ID="you@example.com"
# APPLE_ID_PASSWORD="@keychain:AC_PASSWORD"
# APPLE_TEAM_ID="TEAMID"
